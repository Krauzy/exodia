{
  "name": "exodia-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "electron:start": "tsc -p electron/tsconfig.json && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/main.js",
    "electron:dev": "concurrently \"npm:dev\" \"wait-on http://127.0.0.1:5173 && npm run electron:start\"",
    "electron:pack": "npm run build && electron-builder --dir --publish never",
    "electron:dist": "npm run build && electron-builder --publish never",
    "electron:dist:win": "npm run build && electron-builder --win --publish never",
    "electron:dist:linux": "npm run build && electron-builder --linux --publish never",
    "electron:dist:mac": "npm run build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-table": "^8.20.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "dompurify": "^3.4.11"
  },
  "build": {
    "appId": "dev.exodia.desktop",
    "productName": "Exodia",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend",
        "to": "backend-source",
        "filter": [
          "app/**",
          "alembic.ini",
          "pyproject.toml",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/.mypy_cache/**",
          "!**/.ruff_cache/**",
          "!**/.venv/**",
          "!**/*.egg-info/**",
          "!**/exodia.db"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
